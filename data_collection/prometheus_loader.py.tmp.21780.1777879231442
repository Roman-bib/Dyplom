"""
Загрузчик метрик из Prometheus.

Возвращает raw DataFrame с колонками:
    timestamp, rps, cpu_usage, memory_usage, latency_ms

— тот же формат, что web_traffic.csv, чтобы app.py мог работать без изменений.

Требования: запущенный стек grafana-deploy (docker-compose up -d).
"""

from typing import Optional
import pandas as pd
import requests


DEFAULT_URL = "http://localhost:9090"

# Запросы PromQL → имя колонки в итоговом DataFrame
DEFAULT_QUERIES = {
    "rps": 'sum(rate(http_requests_total[1m])) * 60',
    "cpu_usage": '100 - avg(rate(node_cpu_seconds_total{mode="idle"}[1m])) * 100',
    "memory_usage": '100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)',
    "latency_ms": 'histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le)) * 1000',
}

# Fallback-запросы если node_exporter недоступен (только метрики backend)
BACKEND_ONLY_QUERIES = {
    "rps": 'sum(rate(http_requests_total[1m])) * 60',
    "latency_ms": 'histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le)) * 1000',
}


def _query_range(
    promql: str,
    start: pd.Timestamp,
    end: pd.Timestamp,
    step: str,
    base_url: str,
) -> Optional[pd.Series]:
    """Выполняет один запрос query_range, возвращает Series(index=timestamp, values=float)."""
    try:
        resp = requests.get(
            f"{base_url}/api/v1/query_range",
            params={
                "query": promql,
                "start": start.isoformat() + "Z",
                "end": end.isoformat() + "Z",
                "step": step,
            },
            timeout=10,
        )
        resp.raise_for_status()
        results = resp.json()["data"]["result"]
        if not results:
            return None
        values = results[0]["values"]
        s = pd.Series(
            {pd.to_datetime(ts, unit="s"): float(val) for ts, val in values},
            name="value",
        )
        return s
    except Exception:
        return None


def load_prometheus(
    hours: int = 24,
    step: str = "1m",
    base_url: str = DEFAULT_URL,
    queries: Optional[dict] = None,
) -> pd.DataFrame:
    """
    Загружает метрики из Prometheus за последние N часов.

    Parameters
    ----------
    hours    : глубина выборки (по умолчанию 24 часа)
    step     : шаг между точками ("1m", "5m", "1h" и т.д.)
    base_url : адрес Prometheus
    queries  : словарь {имя_колонки: PromQL} (None = DEFAULT_QUERIES)

    Returns
    -------
    DataFrame с колонками timestamp + все загруженные метрики.
    Колонки совпадают с web_traffic.csv для совместимости с app.py.
    """
    end = pd.Timestamp.utcnow().replace(tzinfo=None)
    start = end - pd.Timedelta(hours=hours)

    q = queries or DEFAULT_QUERIES
    frames = {}

    for col, promql in q.items():
        s = _query_range(promql, start, end, step, base_url)
        if s is not None and len(s) > 0:
            frames[col] = s

    if not frames:
        raise ConnectionError(
            f"Prometheus ({base_url}) не вернул данных. "
            "Убедитесь что grafana-deploy запущен: docker-compose up -d"
        )

    df = pd.DataFrame(frames)
    df.index.name = "timestamp"
    df = df.reset_index()
    df = df.sort_values("timestamp").reset_index(drop=True)

    # Заполняем пропуски (некоторые метрики могут быть недоступны)
    for col in ["rps", "cpu_usage", "memory_usage", "latency_ms"]:
        if col not in df.columns:
            df[col] = 0.0

    df[["rps", "cpu_usage", "memory_usage", "latency_ms"]] = (
        df[["rps", "cpu_usage", "memory_usage", "latency_ms"]]
        .clip(lower=0)
        .fillna(0)
    )

    return df


def check_connection(base_url: str = DEFAULT_URL) -> bool:
    """Проверяет доступность Prometheus."""
    try:
        r = requests.get(f"{base_url}/-/ready", timeout=3)
        return r.status_code == 200
    except Exception:
        return False
